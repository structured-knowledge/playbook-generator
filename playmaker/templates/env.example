# Secrets + gateway base URL for a playmaker instance (spec: openkb-foundation
# / "LiteLLM gateway configuration"). Copy to <kb>/.env and fill in.
# OpenKB / LiteLLM read these from the KB-local .env at runtime.

# The gateway API key.
LLM_API_KEY=your-key-here

# The OpenAI-compatible gateway base URL. LiteLLM routes `openai/<model>`
# requests here. Include the version path if your gateway expects it
# (e.g. https://gateway.example.com/v1).
OPENAI_API_BASE=https://your-gateway.example.com/v1

# Optional: PageIndex Cloud (OCR / faster long-PDF indexing). Local PageIndex
# is used when this is unset.
# PAGEINDEX_API_KEY=your-pageindex-key
