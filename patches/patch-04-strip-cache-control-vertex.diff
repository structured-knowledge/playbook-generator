+def _strip_cache_control_for_vertex(model: str, messages: list[dict]) -> list[dict]:
+    """LOCAL PATCH: drop Anthropic-style ``cache_control`` markers for
+    gemini/Vertex models.
 
+    Vertex tries to honor the marker as a context-caching request and 400s
+    when the tagged block is under its 4096-token caching minimum
+    ("The cached content is of N tokens. The minimum token count to start
+    caching is 4096."). Anthropic-only feature, harmless to drop elsewhere;
+    we only strip it for gemini/vertex so other providers keep caching.
+    See LOCAL_PATCHES.md.
+    """
+    if not model or not any(p in model.lower() for p in ("gemini", "vertex")):
+        return messages
+    cleaned = []
+    for msg in messages:
+        content = msg.get("content")
+        if isinstance(content, list):
+            blocks = [{k: v for k, v in b.items() if k != "cache_control"}
+                      if isinstance(b, dict) else b for b in content]
+            cleaned.append({**msg, "content": blocks})
+        else:
+            cleaned.append(msg)
+    return cleaned
+
